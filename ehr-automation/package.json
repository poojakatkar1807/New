{
  "name": "ehr-automation",
  "version": "1.0.0",
  "description": "Playwright E2E Automation Framework for Healthcare EHR Application",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:chromium": "npx playwright test --project=chromium",
    "test:auth": "npx playwright test tests/auth/",
    "test:patients": "npx playwright test tests/patients/",
    "test:appointments": "npx playwright test tests/appointments/",
    "test:vitals": "npx playwright test tests/vitals/",
    "test:api": "npx playwright test tests/api/",
    "test:e2e": "npx playwright test tests/e2e/",
    "test:smoke": "npx playwright test --grep @smoke",
    "test:regression": "npx playwright test --grep @regression",
    "report": "npx playwright show-report",
    "codegen": "npx playwright codegen http://localhost:3000"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "dotenv": "^16.4.5"
  }
}

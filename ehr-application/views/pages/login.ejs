<%- include('../partials/header') %>

<div class="login-container">
  <div class="login-card">
    <h1 class="login-title" data-testid="login-title">HealthCare EHR</h1>
    <p class="login-subtitle">Sign in to your account</p>

    <% if (error) { %>
      <div class="alert alert-error" data-testid="error-message"><%= error %></div>
    <% } %>

    <form method="POST" action="/login" data-testid="login-form">
      <div class="form-group">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" placeholder="Enter username" data-testid="username-input" autocomplete="off">
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="Enter password" data-testid="password-input">
      </div>
      <button type="submit" class="btn btn-primary btn-full" data-testid="login-btn">Login</button>
    </form>

    <div class="login-help">
      <p>Demo Credentials:</p>
      <p><strong>Doctor:</strong> doctor / Doctor@123</p>
      <p><strong>Nurse:</strong> nurse / Nurse@123</p>
      <p><strong>Admin:</strong> admin / Admin@123</p>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
